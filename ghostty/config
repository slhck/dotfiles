# Config generated by Ghostty Config

shell-integration-features = no-cursor
cursor-style = block
window-colorspace = display-p3
window-save-state = always
unfocused-split-opacity = 0.7
unfocused-split-fill = 000000
theme = GitHub Dark High Contrast
minimum-contrast = 2
foreground = #fefefe
macos-non-native-fullscreen = true
keybind = super+alt+arrow_down=goto_split:next
keybind = super+alt+arrow_up=goto_split:previous

# Linux keybinds (harmless on macOS)
keybind = ctrl+shift+d=new_split:right
keybind = ctrl+shift+e=new_split:down
keybind = ctrl+shift+arrow_down=goto_split:next
keybind = ctrl+shift+arrow_up=goto_split:previous
